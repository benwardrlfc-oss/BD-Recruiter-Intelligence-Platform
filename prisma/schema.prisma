generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Platform layer ─────────────────────────────────────────────────────────────

model Organisation {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  logoUrl  String?

  // Billing
  billingStatus        String   @default("trialing") // trialing | active | past_due | unpaid | cancelled | suspended
  planId               String   @default("trial")    // trial | core | pro | team | enterprise
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique

  // Seat management
  seatCount    Int @default(1)
  seatsUsed    Int @default(0)

  // Trial
  trialStartedAt DateTime?
  trialEndsAt    DateTime?

  // Plan lifecycle
  planStartedAt DateTime?
  planRenewsAt  DateTime?

  // Module entitlements — array of enabled module IDs
  enabledModules String[]

  // Org-level settings (defaults, branding preferences)
  settings Json?

  members      OrgMembership[]
  teams        Team[]
  invites      OrgInvite[]
  subscription Subscription?
  aiUsageLogs  AiUsageLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Team layer ─────────────────────────────────────────────────────────────────

model Team {
  id    String @id @default(cuid())
  orgId String
  name  String

  org     Organisation    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members OrgMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── User layer ─────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  // Onboarding state
  hasCompletedOnboarding Boolean @default(false)
  onboardingStep         Int     @default(0)
  activeProfileId        String?

  // Personal preferences
  colorPalette  String  @default("dark")
  dashboardLayout Json?

  // Platform super admin flag (separate from org roles)
  isSuperAdmin  Boolean @default(false)

  accounts         Account[]
  sessions         Session[]
  memberships      OrgMembership[]
  marketProfiles   MarketProfile[]
  opportunities    Opportunity[]
  candidateUploads CandidateUpload[]
  contentItems     ContentItem[]
  aiUsageLogs      AiUsageLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Org membership (User ↔ Organisation join) ─────────────────────────────────

model OrgMembership {
  id     String @id @default(cuid())
  userId String
  orgId  String

  // Role: org_admin | team_manager | member | read_only
  role         String @default("member")
  seatAssigned Boolean @default(true)
  teamId       String?

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team Team?        @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, orgId])
}

// ── Invitations ────────────────────────────────────────────────────────────────

model OrgInvite {
  id        String   @id @default(cuid())
  orgId     String
  email     String
  role      String   @default("member")
  token     String   @unique @default(cuid())
  expiresAt DateTime
  accepted  Boolean  @default(false)
  invitedBy String?

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ── Subscription ──────────────────────────────────────────────────────────────

model Subscription {
  id     String @id @default(cuid())
  orgId  String @unique

  stripeSubId        String   @unique
  stripePriceId      String
  status             String   // trialing | active | past_due | unpaid | cancelled
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  trialEnd           DateTime?

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── AI usage log ──────────────────────────────────────────────────────────────

model AiUsageLog {
  id     String @id @default(cuid())
  orgId  String
  userId String

  feature       String  // content_studio | bd_scripts | candidate_matcher | market_briefing | signal_explain | eshot
  model         String
  inputTokens   Int     @default(0)
  outputTokens  Int     @default(0)
  estimatedCost Float   @default(0)
  cacheHit      Boolean @default(false)

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ── NextAuth standard models ──────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Feature-level models ──────────────────────────────────────────────────────

model MarketProfile {
  id     String @id @default(cuid())
  userId String

  name          String
  geography     String[]
  sector        String
  subsector     String?
  companyStages String[]
  functionFocus String[]
  modalities    String[]
  investorFocus String[]
  isDefault     Boolean  @default(false)

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItems     ContentItem[]
  intelligenceJobs IntelligenceJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id              String    @id @default(cuid())
  name            String
  sector          String
  subsector       String?
  stage           String?
  geography       String?
  website         String?
  modality        String?
  lifecycleStage  String?
  summary         String?   @db.Text
  employeeCount   Int?
  fundingTotal    Float?
  lastFundingDate DateTime?

  signals          MarketSignal[]
  opportunities    Opportunity[]
  investors        CompanyInvestor[]
  candidateMatches CandidateMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investor {
  id              String   @id @default(cuid())
  name            String
  geography       String?
  stageFocus      String[]
  sectorFocus     String[]
  website         String?
  activitySummary String?  @db.Text
  aum             Float?

  companies CompanyInvestor[]
  signals   MarketSignal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyInvestor {
  companyId      String
  investorId     String
  investmentDate DateTime?
  round          String?
  amount         Float?

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@id([companyId, investorId])
}

model MarketSignal {
  id                String   @id @default(cuid())
  signalType        String
  title             String
  summary           String   @db.Text
  whyItMatters      String   @db.Text
  companyId         String?
  investorId        String?
  sourceUrl         String?
  sourceName        String?
  publishedAt       DateTime @default(now())
  relevanceScore    Float    @default(0)
  impactedFunctions String[]
  tags              String[]
  bdAngle           String?  @db.Text
  geography         String?
  sector            String?

  company  Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  investor Investor? @relation(fields: [investorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model Opportunity {
  id                     String  @id @default(cuid())
  companyId              String
  linkedSignals          String[]
  opportunityScore       Float   @default(0)
  momentumScore          Float   @default(0)
  timingWindow           String?
  recommendedStakeholder String?
  likelyHiringNeed       String? @db.Text
  outreachAngle          String? @db.Text
  lifecycleContext       String? @db.Text
  userId                 String
  isArchived             Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CandidateUpload {
  id              String   @id @default(cuid())
  userId          String
  fileName        String?
  rawText         String   @db.Text
  parsedProfile   Json?
  role            String?
  seniority       String?
  expertise       String[]
  marketRelevance String?  @db.Text

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches CandidateMatch[]

  createdAt DateTime @default(now())
}

model CandidateMatch {
  id                  String  @id @default(cuid())
  candidateUploadId   String
  companyId           String
  matchScore          Float   @default(0)
  reasonForFit        String  @db.Text
  stakeholderToTarget String?
  outreachDraft       String? @db.Text

  candidateUpload CandidateUpload @relation(fields: [candidateUploadId], references: [id], onDelete: Cascade)
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ContentItem {
  id              String   @id @default(cuid())
  userId          String
  contentType     String
  linkedSignals   String[]
  draftText       String   @db.Text
  status          String   @default("draft")
  marketProfileId String?
  platform        String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketProfile MarketProfile? @relation(fields: [marketProfileId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IntelligenceJob {
  id              String    @id @default(cuid())
  status          String    @default("pending")
  startedAt       DateTime?
  completedAt     DateTime?
  signalsFound    Int?
  errors          String?   @db.Text
  marketProfileId String?

  marketProfile MarketProfile? @relation(fields: [marketProfileId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}
