generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  company         String?
  accountType     String?   @default("recruiter")
  activeProfileId String?

  accounts         Account[]
  sessions         Session[]
  marketProfiles   MarketProfile[]
  opportunities    Opportunity[]
  candidateUploads CandidateUpload[]
  contentItems     ContentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MarketProfile {
  id            String   @id @default(cuid())
  userId        String
  name          String
  geography     String[]
  sector        String
  subsector     String?
  companyStages String[]
  functionFocus String[]
  modalities    String[]
  investorFocus String[]
  isDefault     Boolean  @default(false)

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItems     ContentItem[]
  intelligenceJobs IntelligenceJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id              String    @id @default(cuid())
  name            String
  sector          String
  subsector       String?
  stage           String?
  geography       String?
  website         String?
  modality        String?
  lifecycleStage  String?
  summary         String?   @db.Text
  employeeCount   Int?
  fundingTotal    Float?
  lastFundingDate DateTime?

  signals          MarketSignal[]
  opportunities    Opportunity[]
  investors        CompanyInvestor[]
  candidateMatches CandidateMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investor {
  id              String   @id @default(cuid())
  name            String
  geography       String?
  stageFocus      String[]
  sectorFocus     String[]
  website         String?
  activitySummary String?  @db.Text
  aum             Float?

  companies CompanyInvestor[]
  signals   MarketSignal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyInvestor {
  companyId      String
  investorId     String
  investmentDate DateTime?
  round          String?
  amount         Float?

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@id([companyId, investorId])
}

model MarketSignal {
  id                String   @id @default(cuid())
  signalType        String
  title             String
  summary           String   @db.Text
  whyItMatters      String   @db.Text
  companyId         String?
  investorId        String?
  sourceUrl         String?
  sourceName        String?
  publishedAt       DateTime @default(now())
  relevanceScore    Float    @default(0)
  impactedFunctions String[]
  tags              String[]
  bdAngle           String?  @db.Text
  geography         String?
  sector            String?

  company  Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  investor Investor? @relation(fields: [investorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model Opportunity {
  id                     String  @id @default(cuid())
  companyId              String
  linkedSignals          String[]
  opportunityScore       Float   @default(0)
  momentumScore          Float   @default(0)
  timingWindow           String?
  recommendedStakeholder String?
  likelyHiringNeed       String? @db.Text
  outreachAngle          String? @db.Text
  lifecycleContext       String? @db.Text
  userId                 String
  isArchived             Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CandidateUpload {
  id              String   @id @default(cuid())
  userId          String
  fileName        String?
  rawText         String   @db.Text
  parsedProfile   Json?
  role            String?
  seniority       String?
  expertise       String[]
  marketRelevance String?  @db.Text

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches CandidateMatch[]

  createdAt DateTime @default(now())
}

model CandidateMatch {
  id                  String  @id @default(cuid())
  candidateUploadId   String
  companyId           String
  matchScore          Float   @default(0)
  reasonForFit        String  @db.Text
  stakeholderToTarget String?
  outreachDraft       String? @db.Text

  candidateUpload CandidateUpload @relation(fields: [candidateUploadId], references: [id], onDelete: Cascade)
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ContentItem {
  id              String   @id @default(cuid())
  userId          String
  contentType     String
  linkedSignals   String[]
  draftText       String   @db.Text
  status          String   @default("draft")
  marketProfileId String?
  platform        String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketProfile MarketProfile? @relation(fields: [marketProfileId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IntelligenceJob {
  id              String    @id @default(cuid())
  status          String    @default("pending")
  startedAt       DateTime?
  completedAt     DateTime?
  signalsFound    Int?
  errors          String?   @db.Text
  marketProfileId String?

  marketProfile MarketProfile? @relation(fields: [marketProfileId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}
